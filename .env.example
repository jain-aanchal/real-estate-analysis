# AirDNA Enterprise API key (Bearer token)
# Get this from your AirDNA account manager.
AIRDNA_API_KEY=your-airdna-bearer-token-here

# RentCast API key — free tier (50 req/month) for property BR/BA/sqft lookup
# Sign up at https://app.rentcast.io/app/api
RENTCAST_API_KEY=your-rentcast-key-here

# AirROI API key — estimates ADR, occupancy & revenue for any address
# Activate at https://www.airroi.com/api/developer/activate
AIRROI_API_KEY=your-airroi-api-key-here

# Optional overrides
# AIRDNA_BASE=https://api.airdna.co/api/enterprise/v2
# PORT=3200
