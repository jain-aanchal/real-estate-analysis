# AirDNA Enterprise API key (Bearer token)
# Get this from your AirDNA account manager.
AIRDNA_API_KEY=your-airdna-bearer-token-here

# RentCast API key — free tier (50 req/month) for property BR/BA/sqft lookup
# Sign up at https://app.rentcast.io/app/api
RENTCAST_API_KEY=your-rentcast-key-here

# AirROI API key — estimates ADR, occupancy & revenue for any address
# Activate at https://www.airroi.com/api/developer/activate
AIRROI_API_KEY=your-airroi-api-key-here

# Google Maps JS API key — powers the Distressed tab map view.
# Free tier covers 28k loads/mo. Omit to use OpenStreetMap fallback (no key needed).
# Get at https://console.cloud.google.com/google/maps-apis/credentials
# GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# PropertyRadar — paid premium distress-data feed ($89/mo entry tier).
# When set, the Distressed tab prefers PropertyRadar over free scrapers.
# When unset, scrapers run by default. https://developers.propertyradar.com/
# PROPERTYRADAR_API_KEY=your-propertyradar-key-here

# STR Opportunity Finder tab uses the existing RENTCAST_API_KEY above.
# Endpoints used: /v1/listings/sale, /v1/markets, /v1/avm/rent/long-term.
# Pro tier ($299/mo, 5k requests) supports ~156 fresh searches/month.

# Optional overrides
# AIRDNA_BASE=https://api.airdna.co/api/enterprise/v2
# PORT=3200
